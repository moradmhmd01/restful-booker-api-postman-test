    {
      "name": "Create Booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 Created\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "var jsonData = pm.response.json();\r",
              "\r",
              "pm.environment.set(\"bookingId\", jsonData.bookingid);\r",
              "\r",
              "pm.test(\"Verify booking details match request payload\", function () {\r",
              "    pm.expect(jsonData.booking.firstname).to.eql(\"Johnny\");\r",
              "    pm.expect(jsonData.booking.totalprice).to.eql(150);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n\"firstname\" : \"Johnny\",\r\n\"lastname\" : \"Bravo\",\r\n\"totalprice\" : 150,\r\n\"depositpaid\" : true,\r\n\"bookingdates\" : { \"checkin\" : \"2026-07-01\", \"checkout\" : \"2026-07-10\" }\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/booking",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "booking"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Booking Details",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 OK\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "var jsonData = pm.response.json();\r",
              "pm.test(\"Ensure correct record was fetched dynamically\", function () {\r",
              "    pm.expect(jsonData.lastname).to.eql(\"Bravo\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/booking/{{bookingId}}",
          "host": [
            "{{baseUrl}}"
          ],
